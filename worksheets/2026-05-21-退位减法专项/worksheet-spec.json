        {
          "type": "borrowing_chain",
          "expr": "34 - 8",
          "answer": 26,
          "steps": [
            "个位不够减，从十位借1当10",
            "10 + 4 = 14，14 - 8 = 6",
            "十位剩 3 - 1 = 2"
          ],
          "answer_detail": "34 - 8 = 26，个位：14-8=6，十位：3-1=2"
        },
        {
          "type": "borrowing_chain",
          "expr": "62 - 9",
          "answer": 53,
          "steps": [
            "个位2不够减9，从十位借1",
            "10 + 2 = 12，12 - 9 = 3",
            "十位剩 6 - 1 = 5"
          ],
          "answer_detail": "62 - 9 = 53，个位：12-9=3，十位：6-1=5"
        }
      ]
